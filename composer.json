{
    "name": "hi/server",
    "description": "Hi 框架 Server 组件",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "热心网友",
            "email": "anoxia@engineer.com"
        }
    ],
    "require": {
        "php": ">=7.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^0.12",
        "swoole/ide-helper": "^4.6",
        "workerman/workerman": "^4.0"
    },
    "suggest": {
        "ext-swoole": "使用 Swoole 获取更高性能",
        "workerman/workerman": "以 Workerman 作为运行容器，提升服务性能"
    },
    "autoload": {
        "psr-4": {
            "Hi\\Server\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hi\\Server\\Tests\\": "tests/"
        }
    }
}
