    "suggest": {
        "ext-swoole": "\u4f7f\u7528 Swoole \u83b7\u53d6\u66f4\u9ad8\u6027\u80fd",
        "workerman/workerman": "\u4ee5 Workerman \u4f5c\u4e3a\u8fd0\u884c\u5bb9\u5668\uff0c\u63d0\u5347\u670d\u52a1\u6027\u80fd"
